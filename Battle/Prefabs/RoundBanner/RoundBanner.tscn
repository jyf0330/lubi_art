[sub_resource type="Shader" id="Shader_blur"]
code = "shader_type canvas_item;\nuniform sampler2D screen_texture : hint_screen_texture, repeat_disable, filter_linear_mipmap;\nuniform float blur_radius = 4.0;\nuniform vec4 tint_color : source_color = vec4(0.03, 0.02, 0.01, 0.34);\nvoid fragment() {\n\tvec2 offset = SCREEN_PIXEL_SIZE * blur_radius;\n\tvec4 color = texture(screen_texture, SCREEN_UV) * 0.20;\n\tcolor += texture(screen_texture, SCREEN_UV + vec2(offset.x, 0.0)) * 0.10;\n\tcolor += texture(screen_texture, SCREEN_UV - vec2(offset.x, 0.0)) * 0.10;\n\tcolor += texture(screen_texture, SCREEN_UV + vec2(0.0, offset.y)) * 0.10;\n\tcolor += texture(screen_texture, SCREEN_UV - vec2(0.0, offset.y)) * 0.10;\n\tcolor += texture(screen_texture, SCREEN_UV + offset) * 0.10;\n\tcolor += texture(screen_texture, SCREEN_UV - offset) * 0.10;\n\tcolor += texture(screen_texture, SCREEN_UV + vec2(offset.x, -offset.y)) * 0.10;\n\tcolor += texture(screen_texture, SCREEN_UV + vec2(-offset.x, offset.y)) * 0.10;\n\tCOLOR = vec4(mix(color.rgb, tint_color.rgb, tint_color.a), 1.0);\n}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_blur"]
shader = SubResource("Shader_blur")

